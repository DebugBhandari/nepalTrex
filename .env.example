# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-string

# Postgres (matches docker-compose defaults)
DATABASE_URL=postgres://nepaltrex:nepaltrex@localhost:5432/nepaltrex

# Credentials login uses users table in Postgres.
# Seeded default user from db/init.sql
# username: admin
# password: change-me

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
